---
import "../styles/global.css";
import "../styles/themes.css";
import ThemeSwitcher from "../components/ThemeSwitcher.astro";

const { title, description } = Astro.props.frontmatter;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="sitemap" href="/sitemap-index.xml" />
        <script is:inline>
            (function () {
                var t = localStorage.getItem("aether-color-theme");
                if (t) document.documentElement.dataset.colorTheme = t;
            })();
        </script>
    </head>
    <body class="m-0 bg-gray-950 text-gray-50 font-sans antialiased">
        <!-- Nav -->
        <header
            class="flex items-center justify-between px-6 py-4 border-b border-gray-400/20 bg-gray-900/80 backdrop-blur-md sticky top-0 z-50"
        >
            <a
                href="/"
                class="text-xl font-semibold text-gray-50 no-underline font-mono"
                >Aether</a
            >
            <nav class="flex items-center gap-6">
                <a
                    href="/guides/introduction/"
                    class="text-gray-300 no-underline text-sm transition-colors hover:text-gray-50"
                    >Docs</a
                >
                <ThemeSwitcher />
                <a
                    href="https://github.com/joshka/aether"
                    class="flex items-center text-gray-300 no-underline transition-colors hover:text-gray-50"
                    aria-label="GitHub"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
                        ></path>
                    </svg>
                </a>
            </nav>
        </header>

        <main>
            <slot />
        </main>
    </body>
</html>

<script>
    import * as AsciinemaPlayer from "asciinema-player";

    let currentPlayer: ReturnType<typeof AsciinemaPlayer.create> | null = null;

    function createPlayer(src: string) {
        const container = document.getElementById("hero-player");
        if (!container) return;

        if (currentPlayer) {
            currentPlayer.dispose();
            container.innerHTML = "";
        }

        currentPlayer = AsciinemaPlayer.create(src, container, {
            autoPlay: true,
            loop: true,
            speed: 1.5,
            idleTimeLimit: 3,
            fit: "width",
            rows: 24,
            theme: "aether",
        });
    }

    function init() {
        const container = document.getElementById("hero-player");
        if (!container) return;

        const initialSrc = container.dataset.src;
        if (initialSrc) {
            createPlayer(initialSrc);
        }

        const pills = document.querySelectorAll<HTMLButtonElement>(".pill");
        pills.forEach((pill) => {
            pill.addEventListener("click", () => {
                pills.forEach((p) => p.classList.remove("active"));
                pill.classList.add("active");
                const src = pill.dataset.src;
                if (src) createPlayer(src);
            });
        });
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init);
    } else {
        init();
    }
</script>

<style is:global>
    @import "asciinema-player/dist/bundle/asciinema-player.css";

    .asciinema-player-theme-aether {
        --term-color-foreground: #e6edf3;
        --term-color-background: #0d1117;
        --term-color-0: #484f58;
        --term-color-1: #ff7b72;
        --term-color-2: #3fb950;
        --term-color-3: #d29922;
        --term-color-4: #58a6ff;
        --term-color-5: #bc8cff;
        --term-color-6: #39d353;
        --term-color-7: #b1bac4;
        --term-color-8: #6e7681;
        --term-color-9: #ffa198;
        --term-color-10: #56d364;
        --term-color-11: #e3b341;
        --term-color-12: #79c0ff;
        --term-color-13: #d2a8ff;
        --term-color-14: #56d364;
        --term-color-15: #f0f6fc;
    }

    #hero-player .ap-wrapper {
        border-radius: 0;
        border: none;
    }

    #hero-player .ap-control-bar {
        display: none !important;
    }
</style>

<style is:global>
    @reference '../styles/global.css';

    .pill {
        @apply px-3 py-1 rounded-none text-xs font-mono font-medium border-none cursor-pointer transition-colors duration-100 text-gray-500 bg-transparent whitespace-nowrap;
    }

    .pill:hover:not(.active) {
        @apply text-gray-200;
    }

    .pill.active {
        @apply text-accent-400 bg-gray-800/60;
    }

    .pkg-card {
        @apply bg-gray-900/60 border border-gray-400/20 rounded-lg p-5 transition-colors duration-200;
    }

    .pkg-card:hover {
        @apply border-accent-500/30;
    }
</style>
