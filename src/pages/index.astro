---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Aether - A modular AI agent framework for Rust</title>
        <meta
            name="description"
            content="A modular, open-source AI agent framework written in Rust."
        />
        <link rel="sitemap" href="/sitemap-index.xml" />
    </head>
    <body class="m-0 bg-gray-950 text-[#e6edf3] font-sans antialiased">
        <!-- Nav -->
        <header
            class="flex items-center justify-between px-6 py-4 border-b border-gray-400/20 bg-gray-900/80 backdrop-blur-md sticky top-0 z-50"
        >
            <a
                href="/"
                class="text-xl font-semibold text-[#e6edf3] no-underline font-mono"
                >Aether</a
            >
            <nav class="flex items-center gap-6">
                <a
                    href="/guides/introduction/"
                    class="text-gray-300 no-underline text-sm transition-colors hover:text-[#e6edf3]"
                    >Docs</a
                >
                <a
                    href="https://github.com/joshka/aether"
                    class="flex items-center text-gray-300 no-underline transition-colors hover:text-[#e6edf3]"
                    aria-label="GitHub"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                    >
                        <path
                            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
                        ></path>
                    </svg>
                </a>
            </nav>
        </header>

        <main>
            <!-- Hero Section - Two Column Layout -->
            <section class="px-16 pt-16 pb-16 sm:pt-28 sm:pb-20">
                <div class="max-w-400 mx-auto">
                    <div
                        class="grid grid-cols-1 gap-10 items-center lg:grid-cols-[5fr_7fr] lg:gap-16"
                    >
                        <div class="text-center lg:text-left">
                            <h1
                                class="font-mono text-5xl sm:text-6xl lg:text-7xl font-semibold tracking-tight text-white mb-6 [word-spacing:-0.15em]"
                            >
                                A coding agent just for <span
                                    class="italic underline">you</span
                                >
                            </h1>
                            <p
                                class="text-lg sm:text-xl lg:text-2xl text-gray-300 mb-8 leading-relaxed"
                            >
                                Open-source toolkit for custom coding agents,
                                written in Rust. Use any model, any tools and
                                control every token. Run your agent anywhere
                                (TUI, IDE/editor or headless).
                            </p>

                            <div
                                class="flex flex-wrap justify-center lg:justify-start gap-4 mb-8"
                            >
                                <a
                                    href="/guides/introduction/"
                                    class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium bg-accent-600 text-white hover:bg-accent-500 transition-all duration-200 shadow-lg shadow-accent-900/30"
                                >
                                    Build my 1st agent (in 5 minutes) <span
                                        aria-hidden="true">&rarr;</span
                                    >
                                </a>
                                <a
                                    href="https://github.com/joshka/aether"
                                    class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium border border-gray-500 text-gray-200 hover:border-accent-400 hover:text-accent-400 transition-all duration-200"
                                >
                                    View on GitHub
                                    <svg
                                        class="w-4 h-4"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                                        ></path>
                                    </svg>
                                </a>
                            </div>

                            <div
                                class="inline-flex items-center gap-3 px-5 py-3 bg-gray-900/80 border border-gray-400/30 rounded-lg text-gray-200"
                            >
                                <span
                                    class="text-accent-500 font-mono font-semibold select-none"
                                    >$</span
                                >
                                <code class="font-mono text-[#e6edf3]"
                                    >cargo install aether</code
                                >
                            </div>
                        </div>

                        <div>
                            <div
                                class="flex items-end gap-1 mb-2 overflow-x-auto font-mono"
                            >
                                <button
                                    class="pill active"
                                    data-feature="context"
                                    data-src="/demos/demo.cast"
                                    >Any Model</button
                                >
                                <button
                                    class="pill"
                                    data-feature="model"
                                    data-src="/demos/demo.cast"
                                    >Any Tools</button
                                >
                                <button
                                    class="pill"
                                    data-feature="tools"
                                    data-src="/demos/demo.cast"
                                    >Control Every Token</button
                                >
                                <button
                                    class="pill"
                                    data-feature="interface"
                                    data-src="/demos/demo.cast"
                                    >Run Anywhere</button
                                >
                            </div>
                            <div
                                id="hero-player"
                                class="min-h-50 max-h-105 overflow-hidden rounded-lg border border-gray-400/30 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.5)]"
                                data-src="/demos/demo.cast"
                            >
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Three Steps -->
            <section class="px-6 py-20 lg:px-8">
                <div class="mx-auto max-w-6xl">
                    <h2
                        class="font-mono text-2xl sm:text-3xl font-semibold text-accent-500 text-center mb-3"
                    >
                        Build an agent in four steps
                    </h2>
                    <p class="text-gray-400 text-center mb-16 max-w-xl mx-auto">
                        No framework boilerplate. Just config files and plain
                        text.
                    </p>

                    <div class="flex flex-col gap-20">
                        <!-- Step 1: Pick a model — code left, text right -->
                        <div
                            class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center"
                        >
                            <div
                                class="code-panel rounded-lg border border-gray-400/20 overflow-hidden"
                            >
                                <div
                                    class="flex items-center gap-2 px-4 py-2.5 bg-gray-800/80 border-b border-gray-400/20"
                                >
                                    <span
                                        class="w-3 h-3 rounded-full bg-red-500/60"
                                    ></span>
                                    <span
                                        class="w-3 h-3 rounded-full bg-yellow-500/60"
                                    ></span>
                                    <span
                                        class="w-3 h-3 rounded-full bg-green-500/60"
                                    ></span>
                                    <span
                                        class="ml-2 text-xs text-gray-500 font-mono"
                                        >.aether/settings.json</span
                                    >
                                </div>
                                <pre
                                    class="bg-gray-950 text-sm font-mono leading-relaxed overflow-x-auto"><code><div class="diff-ctx"><span class="text-gray-500">&#123;</span></div><div class="diff-add">  <span class="text-accent-400">"agents"</span><span class="text-gray-500">: [</span></div><div class="diff-add">    <span class="text-gray-500">&#123;</span></div><div class="diff-add">      <span class="text-accent-400">"name"</span><span class="text-gray-500">:</span> <span class="text-green-400">"Frontier"</span><span class="text-gray-500">,</span></div><div class="diff-add">      <span class="text-accent-400">"model"</span><span class="text-gray-500">:</span> <span class="text-green-400">"codex:gpt-5.4"</span></div><div class="diff-add">    <span class="text-gray-500">&#125;,</span></div><div class="diff-add">    <span class="text-gray-500">&#123;</span></div><div class="diff-add">      <span class="text-accent-400">"name"</span><span class="text-gray-500">:</span> <span class="text-green-400">"Smart"</span><span class="text-gray-500">,</span></div><div class="diff-add">      <span class="text-accent-400">"model"</span><span class="text-gray-500">:</span> <span class="text-green-400">"zai:glm-5"</span></div><div class="diff-add">    <span class="text-gray-500">&#125;,</span></div><div class="diff-add">    <span class="text-gray-500">&#123;</span></div><div class="diff-add">      <span class="text-accent-400">"name"</span><span class="text-gray-500">:</span> <span class="text-green-400">"Fast"</span><span class="text-gray-500">,</span></div><div class="diff-add">      <span class="text-accent-400">"model"</span><span class="text-gray-500">:</span> <span class="text-green-400">"openrouter:minimax/minimax-m2.5"</span></div><div class="diff-add">    <span class="text-gray-500">&#125;</span></div><div class="diff-add">  <span class="text-gray-500">]</span></div><div class="diff-ctx"><span class="text-gray-500">&#125;</span></div></code></pre>
                            </div>
                            <div>
                                <div
                                    class="inline-block font-mono text-xs font-semibold text-accent-500 bg-accent-500/10 border border-accent-500/20 rounded-full px-3 py-1 mb-4"
                                >
                                    Step 1
                                </div>
                                <h3
                                    class="font-mono text-xl sm:text-2xl font-semibold text-white mb-4"
                                >
                                    Pick a model
                                </h3>
                                <p
                                    class="text-gray-300 text-base leading-relaxed mb-4"
                                >
                                    Swap between any provider with a single
                                    line. Anthropic, OpenAI, OpenRouter,
                                    Bedrock, Ollama &mdash; all through a
                                    unified interface.
                                </p>
                                <p
                                    class="text-gray-400 text-sm leading-relaxed"
                                >
                                    Define multiple agents with different models
                                    and reasoning levels. Use the frontier model
                                    for hard problems, a fast model for quick
                                    tasks, or blend multiple models in an alloy.
                                </p>
                            </div>
                        </div>

                        <!-- Step 2: Pick tools — text left, code right -->
                        <div
                            class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center"
                        >
                            <div class="order-2 lg:order-1">
                                <div
                                    class="inline-block font-mono text-xs font-semibold text-accent-500 bg-accent-500/10 border border-accent-500/20 rounded-full px-3 py-1 mb-4"
                                >
                                    Step 2
                                </div>
                                <h3
                                    class="font-mono text-xl sm:text-2xl font-semibold text-white mb-4"
                                >
                                    Pick your tools
                                </h3>
                                <p
                                    class="text-gray-300 text-base leading-relaxed mb-4"
                                >
                                    Integrate any tool through MCP servers.
                                    Built-in servers for coding, file I/O, and
                                    shell access &mdash; or plug in any
                                    MCP-compatible server.
                                </p>
                                <p
                                    class="text-gray-400 text-sm leading-relaxed"
                                >
                                    Each agent can have its own tool set. Give
                                    your explorer agent read-only access, your
                                    builder full coding tools, or proxy external
                                    servers like Chrome DevTools.
                                </p>
                            </div>
                            <div
                                class="code-panel rounded-lg border border-gray-400/20 overflow-hidden order-1 lg:order-2"
                            >
                                <div
                                    class="flex items-center gap-2 px-4 py-2.5 bg-gray-800/80 border-b border-gray-400/20"
                                >
                                    <span
                                        class="w-3 h-3 rounded-full bg-red-500/60"
                                    ></span>
                                    <span
                                        class="w-3 h-3 rounded-full bg-yellow-500/60"
                                    ></span>
                                    <span
                                        class="w-3 h-3 rounded-full bg-green-500/60"
                                    ></span>
                                    <span
                                        class="ml-2 text-xs text-gray-500 font-mono"
                                        >mcp.json</span
                                    >
                                </div>
                                <pre
                                    class="bg-gray-950 text-sm font-mono leading-relaxed overflow-x-auto"><code><div class="diff-ctx"><span class="text-gray-500">&#123;</span></div><div class="diff-add">  <span class="text-accent-400">"servers"</span><span class="text-gray-500">: &#123;</span></div><div class="diff-add">    <span class="text-accent-400">"coding"</span><span class="text-gray-500">:    &#123;</span> <span class="text-accent-400">"type"</span><span class="text-gray-500">:</span> <span class="text-green-400">"in-memory"</span> <span class="text-gray-500">&#125;,</span></div><div class="diff-add">    <span class="text-accent-400">"skills"</span><span class="text-gray-500">:    &#123;</span> <span class="text-accent-400">"type"</span><span class="text-gray-500">:</span> <span class="text-green-400">"in-memory"</span> <span class="text-gray-500">&#125;,</span></div><div class="diff-add">    <span class="text-accent-400">"tasks"</span><span class="text-gray-500">:     &#123;</span> <span class="text-accent-400">"type"</span><span class="text-gray-500">:</span> <span class="text-green-400">"in-memory"</span> <span class="text-gray-500">&#125;,</span></div><div class="diff-add">    <span class="text-accent-400">"subagents"</span><span class="text-gray-500">: &#123;</span> <span class="text-accent-400">"type"</span><span class="text-gray-500">:</span> <span class="text-green-400">"in-memory"</span> <span class="text-gray-500">&#125;,</span></div><div class="diff-add">    <span class="text-accent-400">"proxy"</span><span class="text-gray-500">: &#123;</span></div><div class="diff-add">      <span class="text-accent-400">"type"</span><span class="text-gray-500">:</span> <span class="text-green-400">"in-memory"</span><span class="text-gray-500">,</span></div><div class="diff-add">      <span class="text-accent-400">"input"</span><span class="text-gray-500">: &#123;</span></div><div class="diff-add">        <span class="text-accent-400">"servers"</span><span class="text-gray-500">: &#123;</span></div><div class="diff-add">          <span class="text-accent-400">"chrome-devtools"</span><span class="text-gray-500">: &#123;</span></div><div class="diff-add">            <span class="text-accent-400">"type"</span><span class="text-gray-500">:</span> <span class="text-green-400">"stdio"</span><span class="text-gray-500">,</span></div><div class="diff-add">            <span class="text-accent-400">"command"</span><span class="text-gray-500">:</span> <span class="text-green-400">"npx"</span><span class="text-gray-500">,</span></div><div class="diff-add">            <span class="text-accent-400">"args"</span><span class="text-gray-500">: [</span><span class="text-green-400">"chrome-devtools-mcp"</span><span class="text-gray-500">]</span></div><div class="diff-add">          <span class="text-gray-500">&#125;</span></div><div class="diff-add">        <span class="text-gray-500">&#125;</span></div><div class="diff-add">      <span class="text-gray-500">&#125;</span></div><div class="diff-add">    <span class="text-gray-500">&#125;</span></div><div class="diff-add">  <span class="text-gray-500">&#125;</span></div><div class="diff-ctx"><span class="text-gray-500">&#125;</span></div></code></pre>
                            </div>
                        </div>

                        <!-- Step 3: Add context — code left, text right -->
                        <div
                            class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center"
                        >
                            <div
                                class="code-panel rounded-lg border border-gray-400/20 overflow-hidden"
                            >
                                <div
                                    class="flex items-center gap-2 px-4 py-2.5 bg-gray-800/80 border-b border-gray-400/20"
                                >
                                    <span
                                        class="w-3 h-3 rounded-full bg-red-500/60"
                                    ></span>
                                    <span
                                        class="w-3 h-3 rounded-full bg-yellow-500/60"
                                    ></span>
                                    <span
                                        class="w-3 h-3 rounded-full bg-green-500/60"
                                    ></span>
                                    <span
                                        class="ml-2 text-xs text-gray-500 font-mono"
                                        >.aether/settings.json</span
                                    >
                                </div>
                                <pre
                                    class="bg-gray-950 text-sm font-mono leading-relaxed overflow-x-auto"><code><div class="diff-ctx"><span class="text-gray-500">&#123;</span></div><div class="diff-ctx">  <span class="text-accent-400">"agents"</span><span class="text-gray-500">: [</span></div><div class="diff-ctx">    <span class="text-gray-500">&#123;</span> <span class="text-accent-400">"name"</span><span class="text-gray-500">:</span> <span class="text-green-400">"Frontier"</span><span class="text-gray-500">,</span> <span class="text-accent-400">"model"</span><span class="text-gray-500">:</span> <span class="text-green-400">"codex:gpt-5.4"</span> <span class="text-gray-500">&#125;,</span></div><div class="diff-ctx">    <span class="text-gray-500">&#123;</span> <span class="text-accent-400">"name"</span><span class="text-gray-500">:</span> <span class="text-green-400">"Smart"</span><span class="text-gray-500">,</span> <span class="text-accent-400">"model"</span><span class="text-gray-500">:</span> <span class="text-green-400">"zai:glm-5"</span> <span class="text-gray-500">&#125;,</span></div><div class="diff-ctx">    <span class="text-gray-500">&#123;</span> <span class="text-accent-400">"name"</span><span class="text-gray-500">:</span> <span class="text-green-400">"Fast"</span><span class="text-gray-500">,</span> <span class="text-accent-400">"model"</span><span class="text-gray-500">:</span> <span class="text-green-400">"openrouter:minimax/minimax-m2.5"</span> <span class="text-gray-500">&#125;</span></div><div class="diff-ctx">  <span class="text-gray-500">],</span></div><div class="diff-add">  <span class="text-accent-400">"prompts"</span><span class="text-gray-500">: [</span><span class="text-green-400">"SYSTEM.md"</span><span class="text-gray-500">,</span> <span class="text-green-400">"AGENTS.md"</span><span class="text-gray-500">]</span></div><div class="diff-ctx"><span class="text-gray-500">&#125;</span></div></code></pre>
                                <div
                                    class="mt-4 rounded-lg border border-gray-400/20 overflow-hidden"
                                >
                                    <div
                                        class="flex items-center gap-2 px-4 py-2 bg-gray-800/80 border-b border-gray-400/20"
                                    >
                                        <span
                                            class="text-xs text-gray-500 font-mono"
                                            >.aether/prompts/SYSTEM.md</span
                                        >
                                    </div>
                                    <pre
                                        class="px-5 py-3 bg-gray-950 text-sm font-mono leading-relaxed overflow-x-auto"><code><span class="text-accent-400"># System Prompt</span>
<span class="text-gray-300">You are an expert senior Rust engineer.</span>
<span class="text-accent-400">## Coding Style</span>
<span class="text-gray-300">- Prefer generics over dynamic boxing</span>
<span class="text-gray-300">- Use async fn in traits directly</span>
<span class="text-gray-500">...</span></code></pre>
                                </div>
                                <div
                                    class="mt-2 rounded-lg border border-gray-400/20 overflow-hidden"
                                >
                                    <div
                                        class="flex items-center gap-2 px-4 py-2 bg-gray-800/80 border-b border-gray-400/20"
                                    >
                                        <span
                                            class="text-xs text-gray-500 font-mono"
                                            >.aether/prompts/AGENTS.md</span
                                        >
                                    </div>
                                    <pre
                                        class="px-5 py-3 bg-gray-950 text-sm font-mono leading-relaxed overflow-x-auto"><code><span class="text-accent-400"># Agents</span>
<span class="text-gray-300">Use the codebase-explorer agent to</span>
<span class="text-gray-300">search code before making changes.</span>
<span class="text-gray-300">Use the Frontier agent for complex</span>
<span class="text-gray-300">multi-file refactors.</span>
<span class="text-gray-500">...</span></code></pre>
                                </div>
                            </div>
                            <div>
                                <div
                                    class="inline-block font-mono text-xs font-semibold text-accent-500 bg-accent-500/10 border border-accent-500/20 rounded-full px-3 py-1 mb-4"
                                >
                                    Step 3
                                </div>
                                <h3
                                    class="font-mono text-xl sm:text-2xl font-semibold text-white mb-4"
                                >
                                    Add context
                                </h3>
                                <p
                                    class="text-gray-300 text-base leading-relaxed mb-4"
                                >
                                    Give your agent the knowledge it needs with
                                    plain markdown files. System prompts, coding
                                    conventions, architecture guides &mdash;
                                    whatever makes your agent effective.
                                </p>
                                <p
                                    class="text-gray-400 text-sm leading-relaxed"
                                >
                                    Each agent loads its own prompts. Share
                                    global context across all agents or give
                                    specialized agents their own instructions.
                                    Skills add reusable domain knowledge.
                                </p>
                            </div>
                        </div>

                        <!-- Step 4: Run it — text left, code right -->
                        <div
                            class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center"
                        >
                            <div class="order-2 lg:order-1">
                                <div
                                    class="inline-block font-mono text-xs font-semibold text-accent-500 bg-accent-500/10 border border-accent-500/20 rounded-full px-3 py-1 mb-4"
                                >
                                    Step 4
                                </div>
                                <h3
                                    class="font-mono text-xl sm:text-2xl font-semibold text-white mb-4"
                                >
                                    Run it
                                </h3>
                                <p
                                    class="text-gray-300 text-base leading-relaxed mb-4"
                                >
                                    Launch your agent in a rich terminal UI with
                                    markdown rendering, syntax highlighting, and
                                    inline diffs. Or run headless for CI
                                    pipelines and automation.
                                </p>
                                <p
                                    class="text-gray-400 text-sm leading-relaxed"
                                >
                                    Switch between agents on the fly, pipe input
                                    from other tools, or expose your agent over
                                    ACP for editor and IDE integrations.
                                </p>
                            </div>
                            <div
                                class="code-panel rounded-lg border border-gray-400/20 overflow-hidden order-1 lg:order-2"
                            >
                                <div
                                    class="flex items-center gap-2 px-4 py-2.5 bg-gray-800/80 border-b border-gray-400/20"
                                >
                                    <span
                                        class="w-3 h-3 rounded-full bg-red-500/60"
                                    ></span>
                                    <span
                                        class="w-3 h-3 rounded-full bg-yellow-500/60"
                                    ></span>
                                    <span
                                        class="w-3 h-3 rounded-full bg-green-500/60"
                                    ></span>
                                    <span
                                        class="ml-2 text-xs text-gray-500 font-mono"
                                        >terminal</span
                                    >
                                </div>
                                <pre
                                    class="p-5 bg-gray-950 text-sm font-mono leading-relaxed overflow-x-auto"><code><span class="text-gray-500"># Interactive TUI</span>
<span class="text-accent-400">$</span> <span class="text-gray-300">aether</span>

<span class="text-gray-500"># Expose over ACP for editor/IDE integration</span>
