---
interface Props {
  src: string;
}

const { src } = Astro.props;
---

<div class="ascii-player-wrapper">
  <div
    id="ascii-player"
    data-src={src}
  ></div>
</div>

<script>
  import * as AsciinemaPlayer from 'asciinema-player';

  function initPlayer() {
    const container = document.getElementById('ascii-player');
    if (!container) return;

    const src = container.dataset.src!;

    AsciinemaPlayer.create(src, container, {
      autoPlay: true,
      loop: true,
      speed: 1,
      idleTimeLimit: 3,
      fit: 'width',
      theme: 'aether',
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlayer);
  } else {
    initPlayer();
  }
</script>

<style is:global>
  @import 'asciinema-player/dist/bundle/asciinema-player.css';

  .asciinema-player-theme-aether {
    --term-color-foreground: #e6edf3;
    --term-color-background: #0d1117;
    --term-color-0: #484f58;
    --term-color-1: #ff7b72;
    --term-color-2: #3fb950;
    --term-color-3: #d29922;
    --term-color-4: #58a6ff;
    --term-color-5: #bc8cff;
    --term-color-6: #39d353;
    --term-color-7: #b1bac4;
    --term-color-8: #6e7681;
    --term-color-9: #ffa198;
    --term-color-10: #56d364;
    --term-color-11: #e3b341;
    --term-color-12: #79c0ff;
    --term-color-13: #d2a8ff;
    --term-color-14: #56d364;
    --term-color-15: #f0f6fc;
  }
</style>

<style>
  .ascii-player-wrapper {
    width: 100%;
  }

  .ascii-player-wrapper :global(.ap-wrapper) {
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid rgba(99, 108, 124, 0.3);
  }
</style>
