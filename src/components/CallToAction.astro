---
interface Props {
    title: string;
    description: string;
}
const { title, description } = Astro.props;
---
<section class="px-16 py-20">
    <div class="mx-auto max-w-2xl text-center">
        <h2 class="font-mono text-2xl sm:text-3xl font-semibold text-accent-500 mb-4">{title}</h2>
        <p class="text-gray-300 mb-8">{description}</p>
        <div class="flex flex-wrap justify-center gap-4">
            <slot />
        </div>
    </div>
</section>
