---
interface Props {
    title: string;
    subtitle: string;
}
const { title, subtitle } = Astro.props;
---
<section class="px-16 py-16">
    <div class="mx-auto max-w-400">
        <h2 class="font-mono text-2xl sm:text-3xl font-semibold text-accent-500 text-center mb-4">{title}</h2>
        <p class="text-gray-300 text-center mb-10 max-w-xl mx-auto">{subtitle}</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <slot />
        </div>
    </div>
</section>
