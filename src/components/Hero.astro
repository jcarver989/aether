---

---

<section class="px-16 pt-16 pb-16 sm:pt-28 sm:pb-20">
    <div class="max-w-350 mx-auto">
        <div
            class="grid grid-cols-1 gap-10 items-center lg:grid-cols-[5fr_7fr] lg:gap-16"
        >
            <div class="text-center lg:text-left">
                <h1
                    class="font-mono text-2xl sm:text-4xl lg:text-5xl font-semibold tracking-tight text-white mb-6 [word-spacing:-0.15em]"
                >
                    The coding agent you actually own.
                </h1>
                <p
                    class="text-base sm:text-lg lg:text-xl text-accent-400 font-mono font-medium mb-4"
                >
                    A blank-slate agent where you control every token. No
                    bundled prompts, tools or telemetry.
                </p>
                <p
                    class="text-sm sm:text-base lg:text-lg text-gray-300 mb-8 leading-relaxed"
                >
                    Use any LLM. Connect any tools (via MCP). Run it in a
                    terminal, IDE/editor, or headless. Open source. Written in
                    Rust.
                </p>

                <div
                    class="flex flex-wrap justify-center lg:justify-start gap-4 mb-8"
                >
                    <a
                        href="/guides/introduction/"
                        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium bg-accent-600 text-white hover:bg-accent-500 transition-all duration-200 shadow-lg shadow-accent-900/30"
                        >Quick Start<span aria-hidden="true">&rarr;</span></a
                    >
                    <a
                        href="https://github.com/joshka/aether"
                        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium border border-gray-500 text-gray-200 hover:border-accent-400 hover:text-accent-400 transition-all duration-200"
                        ><span>View on GitHub</span><svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                            ></path></svg
                        ></a
                    >
                </div>

                <div
                    class="inline-flex items-center gap-3 px-5 py-3 bg-gray-900/80 border border-gray-400/30 rounded-lg text-gray-200"
                >
                    <span
                        class="text-accent-500 font-mono font-semibold select-none"
                        >$</span
                    >
                    <code class="font-mono text-gray-50"
                        >cargo install aether</code
                    >
                </div>
            </div>

            <div>
                <div
                    id="hero-player"
                    class="min-h-50 max-h-105 overflow-hidden rounded-lg border border-gray-400/30 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.5)]"
                    data-src="/demos/demo.cast"
                >
                </div>
            </div>
        </div>
    </div>
</section>
