---
import AsciiPlayer from './AsciiPlayer.astro';

const PAGE_TITLE_ID = '_top';

const entry = Astro.locals.starlightRoute?.entry;
const data = entry?.data ?? {};
const hero = data.hero ?? {};
const { actions = [] } = hero;
const isSplash = data.template === 'splash';
---

{isSplash ? (
<div class="hero-landing">
  <!-- Hero Section -->
  <section class="px-6 py-24 sm:py-32 lg:px-8">
    <div class="mx-auto max-w-5xl text-center">
      <h1 id={PAGE_TITLE_ID} data-page-title class="font-mono text-5xl sm:text-6xl lg:text-7xl font-semibold tracking-tight text-accent-500 mb-6">
        Aether
      </h1>
      <p class="text-xl sm:text-2xl text-gray-300 mb-10 leading-relaxed">
        {hero.tagline || 'A modular AI agent framework for Rust. Your context. Your model. Your tools. Your interface.'}
      </p>

      {actions.length > 0 && (
        <div class="flex flex-wrap justify-center gap-4 mb-12">
          {actions.map((action: any) => (
            <a
              href={action.link}
              class:list={[
                'inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium transition-all duration-200',
                action.variant === 'minimal'
                  ? 'border border-gray-500 text-gray-200 hover:border-accent-400 hover:text-accent-400'
                  : 'bg-accent-600 text-white hover:bg-accent-500 shadow-lg shadow-accent-900/30',
              ]}
            >
              {action.text}
              {action.icon === 'right-arrow' && <span aria-hidden="true">&rarr;</span>}
              {action.icon === 'external' && (
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              )}
            </a>
          ))}
        </div>
      )}

      <div class="demo-player">
        <AsciiPlayer src="/demos/demo.cast" />
      </div>
    </div>
  </section>

  <!-- Four Pillars -->
  <section class="px-6 py-16 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="pillar-card">
          <div class="pillar-icon">&#128196;</div>
          <h3 class="font-mono text-lg font-semibold text-accent-500 mb-2">Your Context</h3>
          <p class="text-gray-300 text-sm leading-relaxed">Automatic context compaction keeps conversations flowing without hitting token limits.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">&#129302;</div>
          <h3 class="font-mono text-lg font-semibold text-accent-500 mb-2">Your Model</h3>
          <p class="text-gray-300 text-sm leading-relaxed">Swap between Anthropic, OpenRouter, Bedrock, Ollama, and more with a single config change.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">&#128295;</div>
          <h3 class="font-mono text-lg font-semibold text-accent-500 mb-2">Your Tools</h3>
          <p class="text-gray-300 text-sm leading-relaxed">Integrate any tool through MCP. File I/O, web search, LSP diagnostics &mdash; all pluggable.</p>
        </div>
        <div class="pillar-card">
          <div class="pillar-icon">&#9000;</div>
          <h3 class="font-mono text-lg font-semibold text-accent-500 mb-2">Your Interface</h3>
          <p class="text-gray-300 text-sm leading-relaxed">Rich TUI with markdown rendering, syntax highlighting, and inline diffs. Or go headless.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture Grid -->
  <section class="px-6 py-16 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-mono text-2xl sm:text-3xl font-semibold text-accent-500 text-center mb-4">Modular by design</h2>
      <p class="text-gray-300 text-center mb-10 max-w-xl mx-auto">Each package does one thing well. Compose only what you need.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="pkg-card">
          <h4 class="font-mono text-accent-400 font-semibold mb-1">aether-core</h4>
          <p class="text-gray-300 text-sm">Agent runtime, context management, and the main conversation loop.</p>
        </div>
        <div class="pkg-card">
          <h4 class="font-mono text-accent-400 font-semibold mb-1">llm</h4>
          <p class="text-gray-300 text-sm">Unified provider interface for Anthropic, OpenAI, Bedrock, Ollama, and more.</p>
        </div>
        <div class="pkg-card">
          <h4 class="font-mono text-accent-400 font-semibold mb-1">mcp-servers</h4>
          <p class="text-gray-300 text-sm">Built-in MCP tool servers: file I/O, bash, web fetch, LSP integration.</p>
        </div>
        <div class="pkg-card">
          <h4 class="font-mono text-accent-400 font-semibold mb-1">wisp</h4>
          <p class="text-gray-300 text-sm">Terminal UI with markdown, syntax highlighting, diffs, and session management.</p>
        </div>
        <div class="pkg-card">
          <h4 class="font-mono text-accent-400 font-semibold mb-1">crucible</h4>
          <p class="text-gray-300 text-sm">Evaluation framework for testing agent behavior with assertions and metrics.</p>
        </div>
        <div class="pkg-card">
          <h4 class="font-mono text-accent-400 font-semibold mb-1">aether-cli</h4>
          <p class="text-gray-300 text-sm">Command-line interface with headless mode, ACP relay, and session persistence.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="px-6 py-20 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-mono text-2xl sm:text-3xl font-semibold text-accent-500 mb-4">Ready to build?</h2>
      <p class="text-gray-300 mb-8">Get started with Aether in minutes. Read the docs, clone the repo, and start building your own AI agents.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/guides/introduction/" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium bg-accent-600 text-white hover:bg-accent-500 transition-all duration-200 shadow-lg shadow-accent-900/30">
          Read the docs <span aria-hidden="true">&rarr;</span>
        </a>
        <a href="https://github.com/joshka/aether" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium border border-gray-500 text-gray-200 hover:border-accent-400 hover:text-accent-400 transition-all duration-200">
          View on GitHub
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</div>
) : null}

<style>
  .hero-landing {
    --accent: #10b981;
  }

  .pillar-card {
    background: linear-gradient(135deg, rgba(45, 51, 59, 0.5), rgba(22, 27, 34, 0.8));
    border: 1px solid rgba(99, 108, 124, 0.3);
    border-radius: 0.75rem;
    padding: 1.5rem;
    transition: border-color 0.2s, transform 0.2s;
  }

  .pillar-card:hover {
    border-color: rgba(16, 185, 129, 0.4);
    transform: translateY(-2px);
  }

  .pillar-icon {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .pkg-card {
    background: rgba(22, 27, 34, 0.6);
    border: 1px solid rgba(99, 108, 124, 0.2);
    border-radius: 0.5rem;
    padding: 1.25rem;
    transition: border-color 0.2s;
  }

  .pkg-card:hover {
    border-color: rgba(16, 185, 129, 0.3);
  }

  .demo-player {
    min-width: 0;
  }
</style>
