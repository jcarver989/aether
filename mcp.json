{
  "servers": {
    "coding": {
      "type": "in-memory"
    },
    "skills": {
      "type": "in-memory",
      "args": ["--dir", "$HOME/.aether"]
    },
    "tasks": {
      "type": "in-memory"
    },
    "subagents": {
      "type": "in-memory"
    },
    "survey": {
      "type": "in-memory"
    },
    "proxy": {
      "type": "in-memory",
      "input": {
        "servers": {
	  "chrome-devtools": {
            "type": "stdio",
	    "command": "npx",
	      "args": ["-y", "chrome-devtools-mcp@latest", "--no-usage-statistics"]
	    }
        }
      }
    }
  }
}
