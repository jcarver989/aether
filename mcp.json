{
  "servers": {
    "coding": {
      "type": "in-memory",
      "args": ["--rules-dir", "./.aether/skills"]
    },
    "skills": {
      "type": "in-memory",
      "args": ["--dir", "./.aether/skills", "--notes-dir", "./.aether/notes"]
    },
    "tasks": {
      "type": "in-memory"
    },
    "subagents": {
      "type": "in-memory"
    },
    "survey": {
      "type": "in-memory"
    },
    "proxy": {
      "type": "in-memory",
      "input": {
        "servers": {
          "playwright": {
            "type": "stdio",
            "command": "npx",
            "args": ["@playwright/mcp@latest"]
          }
        }
      }
    }
  }
}
