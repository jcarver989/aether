{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Generated by pnpm --filter @aether-agent/sdk generate:config-types. Do not edit manually.",
  "title": "AetherConfig",
  "type": "object",
  "properties": {
    "agent": {
      "type": ["string", "null"]
    },
    "agents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/AgentConfig"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false,
  "required": ["agents"],
  "$defs": {
    "AgentConfig": {
      "type": "object",
      "properties": {
        "agentInvocable": {
          "type": "boolean",
          "default": false
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "mcp": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/McpConfigSourceConfig"
          }
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "prompts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PromptSource"
          },
          "minItems": 1
        },
        "reasoningEffort": {
          "anyOf": [
            {
              "$ref": "#/$defs/ReasoningEffort"
            },
            {
              "type": "null"
            }
          ]
        },
        "tools": {
          "$ref": "#/$defs/ToolFilter"
        },
        "userInvocable": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false,
      "anyOf": [
        {
          "properties": {
            "userInvocable": {
              "const": true
            }
          },
          "required": ["userInvocable"]
        },
        {
          "properties": {
            "agentInvocable": {
              "const": true
            }
          },
          "required": ["agentInvocable"]
        }
      ],
      "required": ["name", "description", "model", "prompts"]
    },
    "McpConfigSourceConfig": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "proxy": {
              "type": "boolean",
              "default": false
            },
            "type": {
              "type": "string",
              "const": "file"
            }
          },
          "additionalProperties": false,
          "required": ["type", "path"]
        },
        {
          "type": "object",
          "properties": {
            "servers": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/$defs/RawMcpServerConfig"
              }
            },
            "type": {
              "type": "string",
              "const": "inline"
            }
          },
          "additionalProperties": false,
          "required": ["type", "servers"]
        }
      ]
    },
    "PromptSource": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "text": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "text"
            }
          },
          "additionalProperties": false,
          "required": ["type", "text"]
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "file"
            }
          },
          "additionalProperties": false,
          "required": ["type", "path"]
        },
        {
          "type": "object",
          "properties": {
            "pattern": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "glob"
            }
          },
          "additionalProperties": false,
          "required": ["type", "pattern"]
        }
      ]
    },
    "RawMcpServerConfig": {
      "description": "Server connection definition.\n\nWhen `\"type\"` is omitted, defaults to `\"stdio\"` for compatibility with\nClaude Code's `.mcp.json` format.",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "args": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              }
            },
            "command": {
              "type": "string"
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "type": {
              "type": "string",
              "const": "stdio"
            }
          },
          "required": ["type", "command"]
        },
        {
          "type": "object",
          "properties": {
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "type": {
              "type": "string",
              "const": "http"
            },
            "url": {
              "type": "string"
            }
          },
          "required": ["type", "url"]
        },
        {
          "type": "object",
          "properties": {
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {}
            },
            "type": {
              "type": "string",
              "const": "sse"
            },
            "url": {
              "type": "string"
            }
          },
          "required": ["type", "url"]
        },
        {
          "description": "In-memory transport (Aether extension) - requires a registered factory\nThe factory is looked up using the server name from the mcp.json key.\n\nWhen `input` contains a `\"servers\"` key, this is treated as a tool-proxy\nconfiguration: nested server configs are parsed and validated, producing\na `McpServerConfig::ToolProxy` at runtime.",
          "type": "object",
          "properties": {
            "args": {
              "type": "array",
              "default": [],
              "items": {
                "type": "string"
              }
            },
            "input": {
              "default": null
            },
            "type": {
              "type": "string",
              "const": "in-memory"
            }
          },
          "required": ["type"]
        }
      ]
    },
    "ReasoningEffort": {
      "type": "string",
      "enum": ["low", "medium", "high", "xhigh"]
    },
    "ToolFilter": {
      "description": "Filter for restricting which tools an agent can use.\n\nSupports `allow` (allowlist) and `deny` (blocklist) with trailing `*` wildcards.\nIf both are set, allow is applied first, then deny removes from the result.\nAn empty filter (the default) allows all tools.",
      "type": "object",
      "properties": {
        "allow": {
          "description": "If non-empty, only tools matching these patterns are allowed.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deny": {
          "description": "Tools matching these patterns are removed.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
